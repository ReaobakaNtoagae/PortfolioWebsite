<Window x:Class="PROG7312PRACTICE.InfoPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Info"
        Height="550" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#f0f4f8"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="White" CornerRadius="20" Padding="15" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0 0 0 10">
                <TextBlock Text="📌 Event Details" FontSize="22" FontWeight="Bold" Foreground="#2c3e50" DockPanel.Dock="Left"/>
                <Button Content="✖" Width="36" Height="36" DockPanel.Dock="Right"
                        Background="#e74c3c" Foreground="White" FontWeight="Bold"
                        Click="Close_Click"
                        BorderThickness="0" Cursor="Hand"/>
            </DockPanel>

            <!-- Content Scroll -->
            <ScrollViewer Grid.Row="1">
                <StackPanel>

                    <!-- Pending Events -->
                    <TextBlock Text="📦 Pending Events" FontSize="18" FontWeight="Bold" Foreground="#34495e" Margin="0 8"/>
                    <ItemsControl x:Name="PendingList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#ecf0f1" CornerRadius="12" Padding="8" Margin="4" >
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border CornerRadius="8" Grid.Column="0" Width="50" Height="50" ClipToBounds="True">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="10 0 0 0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#2c3e50"/>
                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="12" Foreground="#7f8c8d"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Newly Added Events -->
                    <TextBlock Text="🆕 Newly Added" FontSize="18" FontWeight="Bold" Foreground="#34495e" Margin="0 12 0 8"/>
                    <ItemsControl x:Name="NewList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#ecf0f1" CornerRadius="12" Padding="8" Margin="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border CornerRadius="8" Grid.Column="0" Width="50" Height="50" ClipToBounds="True">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="10 0 0 0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#2c3e50"/>
                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="12" Foreground="#7f8c8d"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Next Upcoming Event -->
                    <TextBlock Text="⏱ Next Upcoming Event" FontSize="18" FontWeight="Bold" Foreground="#34495e" Margin="0 12 0 8"/>
                    <Border Background="#ffffff" CornerRadius="16" Padding="12" BorderBrush="#3498db" BorderThickness="1" >
                        <StackPanel x:Name="NextEventPanel">
                            <Border CornerRadius="12" Height="120" ClipToBounds="True" Margin="0 0 0 8">
                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="#2c3e50"/>
                            <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" Foreground="#7f8c8d" Margin="0 2 0 0"/>
                            <TextBlock Text="{Binding Category}" Foreground="#3498db" Margin="0 2 0 0"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0 4 0 0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
                <Button Content="Close" Width="80" Height="32" Background="#e74c3c" Foreground="White" FontWeight="Bold"
                        Click="Close_Click" BorderThickness="0"  Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
