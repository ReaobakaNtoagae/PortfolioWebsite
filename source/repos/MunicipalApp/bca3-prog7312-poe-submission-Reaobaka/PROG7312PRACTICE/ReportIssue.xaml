<Window x:Class="PROG7312PRACTICE.ReportIssue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ReportIssueTitle}" 
        Height="450" Width="800" WindowState="Maximized" WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True" Background="#F9F9F9">

        <!-- Sticky Progress Bar Header -->
        <Border DockPanel.Dock="Top" Background="White" Padding="20" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{DynamicResource Progress}" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,10"/>
                <ProgressBar x:Name="ProgressBarReporting" Height="25" Minimum="0" Maximum="100" Value="0" Foreground="#2196F3"/>
            </StackPanel>
        </Border>

        <!-- Scrollable form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20">
            <Border Background="White" BorderBrush="#2196F3" BorderThickness="1" CornerRadius="10" Padding="20" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#888888" BlurRadius="10" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Width="700">

                    <TextBlock Text="{DynamicResource ReportIssueTitle}" 
                               FontSize="28" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>

                    <!-- Location -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,15" HorizontalAlignment="Left">
                        <TextBlock Text="{DynamicResource LocationPrompt}" 
                                   FontSize="16" Foreground="#555555"/>
                        <Border Background="White" HorizontalAlignment="Left" Margin="0,5,0,0" 
                                BorderBrush="#2196F3" BorderThickness="1" CornerRadius="5" Width="315" Height="35">
                            <TextBox x:Name="LocationTextBox" Foreground="#555555" Padding="8" 
                                     Background="Transparent" BorderThickness="0" FontSize="14" TextChanged="LocationTextBox_TextChanged"/>
                        </Border>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,15" HorizontalAlignment="Left">
                        <TextBlock Text="{DynamicResource CategoryPrompt}" 
                                   FontSize="16" Foreground="#555555"/>
                        <Border Background="White" Margin="0,5,0,0" 
                                BorderBrush="#2196F3" BorderThickness="1" CornerRadius="5" Width="300" Height="80">
                            <ListBox x:Name="CategoryListBox" Background="Transparent" BorderThickness="0" FontSize="14" SelectionChanged="CategoryListBox_SelectionChanged"/>
                        </Border>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,15" HorizontalAlignment="Left">
                        <TextBlock Text="{DynamicResource DescriptionPrompt}" 
                                   FontSize="16" Foreground="#555555"/>
                        <Border Background="White" Margin="0,5,0,0" 
                                BorderBrush="#2196F3" BorderThickness="1" CornerRadius="5" Width="500" Height="120">
                            <RichTextBox x:Name="DescriptionTextBox" Padding="8" 
                                         Background="Transparent" BorderThickness="0" FontSize="14" TextChanged="DescriptionTextBox_TextChanged"/>
                        </Border>
                    </StackPanel>

                    <!-- Upload -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,15" HorizontalAlignment="Left">
                        <TextBlock Text="{DynamicResource UploadPrompt}" 
                                   FontSize="16" Foreground="#555555"/>
                        <Button Content="{DynamicResource UploadButton}" Width="250" Margin="0,10,0,0" Height="50" 
                                Click="Upload_Click" Cursor="Hand" FontWeight="Bold" HorizontalAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#2196F3" Margin="0,5,0,0" CornerRadius="5" BorderBrush="#2196F3" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Border Width="250" Height="150" Margin="0,10,0,0" BorderBrush="#CCCCCC" 
                                BorderThickness="1" CornerRadius="5" Background="White" HorizontalAlignment="Left">
                            <Image x:Name="UploadedImage" Stretch="Uniform" />
                        </Border>
                    </StackPanel>

                    <!-- Submit -->
                    <Button Width="150" Height="50" Click="Submit_Click" Cursor="Hand" 
                            HorizontalAlignment="Center" Margin="0,10,0,10" FontWeight="Bold"
                            Content="{DynamicResource SubmitButton}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2196F3" CornerRadius="5" BorderBrush="#2196F3" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Back -->
                    <Button Width="250" Height="50" Click="Back_Click" Cursor="Hand" 
                            HorizontalAlignment="Center" Margin="0,10,0,10" FontWeight="Bold"
                            Content="{DynamicResource BackButton}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2196F3" CornerRadius="5" BorderBrush="#2196F3" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Label x:Name="MessageLabel" Content="" FontSize="16" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
