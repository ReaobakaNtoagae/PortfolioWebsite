<Window x:Class="PROG7312PRACTICE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800"  WindowState="Maximized" WindowStartupLocation="CenterScreen">

   
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Images/community.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        
        <Border Background="#AAFFFFFF" CornerRadius="10" Padding="30" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Center">

                <TextBlock Text="{DynamicResource WelcomeMessage}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#333333" 
                          HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource TaskMessage}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#333333" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

              
                <Button Content="{DynamicResource ReportIssueButton}"  Height="45" FontSize="16" Click="ReportIssue_Click" Cursor="Hand" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#2196F3" CornerRadius="5" BorderBrush="#2196F3" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="LocalEvents"   Content="{DynamicResource LocalEventsButton}" ToolTip="" Margin="0,10,0,0" Height="45" FontSize="16"  Click="Events_Click" Cursor="Hand" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#4CAF50" CornerRadius="5" BorderBrush="#4CAF50" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="ServiceStatusButton" Content="{DynamicResource StatusButton}" Margin="0,10,0,0" Height="45" FontSize="16" Click="Status_Click" Cursor="Hand" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#FF9800" CornerRadius="5" BorderBrush="#FF9800" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
