<Window x:Class="PROG7312PRACTICE.ServiceRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Municipal Service Portal"
        Width="1200" Height="820"
        Background="#F3F4F8"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Color Palette -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#EEF2FF" Offset="0"/>
            <GradientStop Color="#E0E7FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#4338CA"/>
        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FBBF24" Offset="0"/>
            <GradientStop Color="#F59E0B" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="TextBrush" Color="#1E1E2F"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="#F7F9FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="InputFocusBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="ListHoverBrush" Color="#EFF6FF"/>

        <!-- Status Colors -->
        <SolidColorBrush x:Key="StatusPendingBrush" Color="#FBBF24"/>
        <SolidColorBrush x:Key="StatusInProgressBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="StatusCompletedBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="StatusUrgentBrush" Color="#EF4444"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="CardShadow" Color="#33000000" BlurRadius="12" ShadowDepth="4" Opacity="0.3"/>
        <DropShadowEffect x:Key="ButtonShadow" Color="#22000000" BlurRadius="6" ShadowDepth="2" Opacity="0.3"/>
        <DropShadowEffect x:Key="InputShadow" Color="#22000000" BlurRadius="6" ShadowDepth="1" Opacity="0.15"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C3AED" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4338CA" Offset="0"/>
                                <GradientStop Color="#4F46E5" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Effect" Value="{StaticResource InputShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource InputFocusBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="2">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ListHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDEAFE"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Progress Gradient -->
        <LinearGradientBrush x:Key="ProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#6366F1" Offset="0"/>
            <GradientStop Color="#4F46E5" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="{StaticResource HeaderBrush}" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">

                <!-- Back Button -->
                <Button Content="← Back"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="BackButton_Click"
                        Style="{StaticResource PrimaryButton}"
                        DockPanel.Dock="Left"/>

                <TextBlock Text="City Services Tracker"
                           FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="10" Background="White" BorderThickness="1" BorderBrush="#DDD" Padding="2" Margin="0,0,10,0">
                        <TextBox x:Name="SearchText" Width="280" Padding="8" Background="Transparent" BorderThickness="0" ToolTip="Enter request ID or description"/>
                    </Border>

                    <Button Content="Track Request" 
                            Click="BtnSearch_Click" 
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Border CornerRadius="8" Padding="6" Background="#E0E7FF" Margin="0,0,0,10">
                        <TextBlock Text="Service Categories" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryDarkBrush}"/>
                    </Border>
                    <ListBox x:Name="CategoryList" Background="#F9FAFB" BorderThickness="0" Height="180" FontSize="13"/>

                    <Separator Margin="0,14,0,14"/>

                    <Border CornerRadius="8" Padding="6" Background="#FEF3C7" Margin="0,0,0,8">
                        <TextBlock Text="Urgent Requests" FontWeight="SemiBold" FontSize="15" Foreground="#B45309"/>
                    </Border>
                    <ListView x:Name="PriorityList" Background="#F9FAFB" BorderThickness="0" Height="280" FontSize="13" HorizontalContentAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- CENTER PANEL -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                <StackPanel>
                    <TextBlock Text="Recent Requests" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="{StaticResource TextBrush}"/>

                    <ListView x:Name="RequestsList" Height="580" BorderThickness="0" SelectionChanged="RequestsList_SelectionChanged"
                              HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="14" Margin="4" BorderBrush="#E5E7EB" BorderThickness="1" HorizontalAlignment="Stretch" Effect="{StaticResource CardShadow}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Description}" FontWeight="Bold" FontSize="14.5" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Department}" Foreground="{StaticResource MutedBrush}" FontSize="12.5"/>

                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,6,0,4" Foreground="{StaticResource ProgressBrush}" Background="#E5E7EB"/>

                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusPendingBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusInProgressBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusCompletedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Urgent">
                                                            <Setter Property="Foreground" Value="{StaticResource StatusUrgentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="{Binding RequestId}" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="2">
                <StackPanel>
                    <Border CornerRadius="8" Padding="6" Background="#E0F2FE" Margin="0,0,0,10">
                        <TextBlock Text="Request Details" FontWeight="Bold" FontSize="16" Foreground="#0369A1"/>
                    </Border>
                    <Border Margin="0,0,0,10" Background="#F9FAFB" Padding="12" CornerRadius="10">
                        <StackPanel>
                            <TextBlock x:Name="TxtId" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="TxtDescription" FontSize="13"/>
                            <TextBlock x:Name="TxtDepartment" FontSize="13"/>
                            <TextBlock x:Name="TxtStatus" FontSize="13"/>
                            <TextBlock x:Name="TxtPriority" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="8" Padding="6" Background="#E9F5EC" Margin="0,10,0,6">
                        <TextBlock Text="History" FontWeight="SemiBold" FontSize="15" Foreground="#047857"/>
                    </Border>
                    <ListBox x:Name="HistoryList" Height="100" Background="#F9FAFB" BorderThickness="0" FontSize="13"/>

                    <Border CornerRadius="8" Padding="6" Background="#FFF1F3" Margin="0,10,0,6">
                        <TextBlock Text="Service Network" FontWeight="SemiBold" FontSize="15" Foreground="#B91C1C"/>
                    </Border>
                    <Canvas x:Name="GraphCanvas" Height="250" Background="#F3F4F6" Margin="0,0,0,8" ClipToBounds="True" SnapsToDevicePixels="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
