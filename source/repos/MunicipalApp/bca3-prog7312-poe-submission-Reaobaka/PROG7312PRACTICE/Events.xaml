<Window x:Class="PROG7312PRACTICE.Events"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Events Hub"
        Height="820"
        Width="1050"
        Background="#f5f7fb"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" ShadowDepth="2" Color="#888" BlurRadius="8" Opacity="0.4"/>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <DockPanel Grid.Row="0" Margin="0 0 0 10" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="⬅ Back"
                        Width="80"
                        Height="36"
                        Style="{StaticResource RoundedButton}"
                        Click="Back_Click"/>
                <TextBlock Text="🌍 Local Announcements and Events"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2c3e50"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>

            <Button Content="ℹ️ Info"
                    Width="44"
                    Height="36"
                    Style="{StaticResource RoundedButton}"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Click="OpenInfoPopup_Click"/>
        </DockPanel>

        <!-- FILTERS -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 15">
            <ComboBox x:Name="CategoryFilter" Width="150" Height="35" Margin="0 0 8 0"/>
            <DatePicker x:Name="DateFilter" Width="160" Height="35" Margin="0 0 8 0"/>
            <Button Content="🔍 Search" Width="100" Height="35" Margin="0 0 8 0" Click="Search_Click" Style="{StaticResource RoundedButton}"/>
            <Button Content="📅 Show All" Width="110" Height="35" Margin="0 0 8 0" Click="ShowAll_Click" Style="{StaticResource RoundedButton}"/>
            <Button Content="⏭ Next Event" Width="120" Height="35" Click="NextEvent_Click" Style="{StaticResource RoundedButton}"/>
        </StackPanel>

        <!-- RECOMMENDED EVENTS -->
        <StackPanel Grid.Row="2" Margin="0 0 0 15">
            <TextBlock Text="Recommended Events For You" FontSize="20" FontWeight="Bold" Foreground="#2c3e50" Margin="6 0 0 8"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="Recommendations">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Width="220" Margin="8" Padding="10" CornerRadius="12" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <Border CornerRadius="10" ClipToBounds="True">
                                        <Image Source="{Binding ImageUrl}" Width="200" Height="100" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#2c3e50" TextWrapping="Wrap" Margin="0 6 0 2"/>
                                    <TextBlock Text="{Binding Category}" Foreground="#0078D7" FontSize="12"/>
                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM dd}'}" Foreground="#888" FontSize="12" Margin="0 2 0 0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- EVENT LIST -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EventList" Margin="0 0 0 10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="8" Padding="15" CornerRadius="10" BorderBrush="#e0e0e0" BorderThickness="1" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="8" Width="130" Height="90" ClipToBounds="True" VerticalAlignment="Top">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="15 0 0 0">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" Foreground="#2c3e50"/>
                                    <TextBlock Text="{Binding Category}" FontStyle="Italic" Foreground="#0078D7" Margin="0 2 0 0"/>
                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:MMMM dd, yyyy}'}" Foreground="#555"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#444" Margin="0 6 0 0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- RECENTLY VIEWED -->
        <StackPanel Grid.Row="4" Margin="0 8 0 0">
            <TextBlock Text="🕒 Recently Viewed" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="6 6 0 8"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="RecentlyViewed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Width="180" Margin="6" Padding="10" CornerRadius="10" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <Border CornerRadius="8" ClipToBounds="True" Height="80">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#2c3e50" Margin="0 6 0 2"/>
                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM dd}'}" Foreground="#888" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
